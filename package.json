{
  "name": "kubepilot-console",
  "version": "0.1.0",
  "description": "A local Kubernetes agent console that projects Codex and Claude Code cluster operations into a controlled terminal.",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n server,web -c cyan,green \"tsx watch server/index.ts\" \"vite --host 127.0.0.1\"",
    "app": "node scripts/fix-pty-perms.cjs && concurrently -k -n server,web,app -c cyan,green,magenta \"tsx watch server/index.ts\" \"vite --host 127.0.0.1\" \"wait-on tcp:8787 http://127.0.0.1:5174 && node electron/launch.cjs .\"",
    "build": "tsc -b && vite build",
    "start": "NODE_ENV=production tsx server/index.ts"
  },
  "dependencies": {
    "@ast-grep/lang-bash": "^0.0.8",
    "@ast-grep/napi": "^0.44.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "electron": "^33.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  }
}
